    "seed:sources": "tsx --env-file=.env.local scripts/seed-sources.ts",
    "seed:cn-news-sources": "tsx --env-file=.env.local scripts/seed-cn-news-sources.ts",
    "fetch:articles": "tsx --env-file=.env.local scripts/fetch-articles.ts",
