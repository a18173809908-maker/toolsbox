# Copy to .env.local and fill in. .env.local is gitignored.

# ── Database ─────────────────────────────────────────────────────────────────
# Neon Postgres connection string
DATABASE_URL=postgres://...

# ── LLM ──────────────────────────────────────────────────────────────────────
# Provider switch: 'deepseek' (default) | 'openai' | 'anthropic' (not implemented)
LLM_PROVIDER=deepseek

# Standard tier — 客观字段、翻译、轻量任务
LLM_MODEL=deepseek-chat

# Premium tier — 立场字段、反套话审计、需要判断的任务
# 缺省时 fallback 到 LLM_MODEL。Q12 决策：当前 standard 和 premium 都用 DeepSeek。
# 未来要升 Claude Sonnet：LLM_MODEL_PREMIUM=claude-sonnet-4-6-20251022（需加 anthropic adapter）
LLM_MODEL_PREMIUM=deepseek-chat

# Provider API keys (按 LLM_PROVIDER 设对应的一个)
DEEPSEEK_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Cron ─────────────────────────────────────────────────────────────────────
# Shared secret for /api/cron/* endpoints. Set on Vercel + GitHub Actions secrets.
CRON_SECRET=...
